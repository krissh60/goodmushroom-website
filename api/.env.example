# Good Mushroom — contact form backend
# Copy this file to /var/www/goodmushroom/api/.env on the VPS, fill in real values, chmod 600.
# Never commit the real .env.

# Recipient inboxes (match what was hardcoded in the original mailto: forms)
RECIPIENT_PRIMARY=krish@goodmushroom.in
RECIPIENT_SECONDARY=anmol@goodmushroom.in

# SMTP — Hostinger example. Swap for your provider.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=hello@goodmushroom.in
SMTP_PASS=replace_with_real_smtp_password
SMTP_FROM=hello@goodmushroom.in
SMTP_FROM_NAME=Good Mushroom Website

# Per-IP submission limit (sliding 1-hour window)
RATE_LIMIT_PER_HOUR=20
